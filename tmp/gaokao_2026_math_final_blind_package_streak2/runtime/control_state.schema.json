{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "wu-boshi-perspective/runtime/control-state.schema.json",
  "title": "Wu Boshi Runtime Control State",
  "description": "Persisted runtime control state only. This schema intentionally covers the minimal serialized control face and excludes derived readout surfaces. Readouts such as self_check_agenda, control_signals, closure_nucleus, gap_object, resume_bridge, skill_field, skill_competition, skill_inhibition, control_bridge, skill_authority_bridge, interlayer_discharge_bridge, inhibition_state, and primitive_semantics may be computed from persisted state but must not be written into documents validated by this schema.",
  "$comment": "If a host wants any derived readout surface, compute or publish it ephemerally after loading persisted state. Do not extend the serialized control-state document with parallel readout objects.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "current_object",
    "current_debt",
    "next_bite",
    "asked_medium_surface",
    "revocation_handle",
    "uncertainty_mode",
    "primary_slot",
    "bound_program",
    "layer_composition_if_any",
    "release_veto",
    "output_status",
    "memory_residue"
  ],
  "allOf": [
    {
      "description": "Explicit persisted-vs-derived boundary. These derived surface names are rejected here even if some host later relaxes or bypasses the main property list.",
      "not": {
        "anyOf": [
          { "required": ["self_check_agenda"] },
          { "required": ["control_signals"] },
          { "required": ["closure_nucleus"] },
          { "required": ["gap_object"] },
          { "required": ["resume_bridge"] },
          { "required": ["skill_field"] },
          { "required": ["skill_competition"] },
          { "required": ["skill_inhibition"] },
          { "required": ["control_bridge"] },
          { "required": ["skill_authority_bridge"] },
          { "required": ["interlayer_discharge_bridge"] },
          { "required": ["inhibition_state"] },
          { "required": ["primitive_semantics"] }
        ]
      }
    }
  ],
  "properties": {
    "current_object": { "type": "string", "minLength": 1 },
    "current_seam": { "type": "string", "minLength": 0 },
    "current_debt": { "type": "string", "minLength": 1 },
    "next_bite": { "type": "string", "minLength": 1 },
    "asked_medium_surface": { "type": "string", "minLength": 1 },
    "revocation_handle": { "type": "string", "minLength": 1 },
    "uncertainty_mode": {
      "type": "string",
      "enum": ["high", "low", "mixed", "unknown"]
    },
    "primary_slot": { "type": "string", "minLength": 1 },
    "bound_program": {
      "description": "Persisted next executable local bite. This is the durable stateful action slot, not a serialized control_bridge readout.",
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["kind", "target", "operation"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["write", "check", "读出", "见证"]
        },
        "target": { "type": "string", "minLength": 1 },
        "operation": { "type": "string", "minLength": 1 },
        "success_signal": { "type": "string", "minLength": 1 }
      }
    },
    "layer_composition_if_any": {
