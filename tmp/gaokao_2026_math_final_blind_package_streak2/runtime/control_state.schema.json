      "description": "Persisted monitor-to-action gate purchase when one already-local checking pressure temporarily buys authority for one executable bite. This is the durable state counterpart, not a serialized inhibition_state readout.",
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": [
        "source_focus",
        "source_target",
        "demoted_continuation",
        "authority_until"
      ],
      "properties": {
        "source_focus": {
          "type": "string",
          "enum": ["seam", "rival", "carrier", "asked_medium"]
        },
        "source_target": { "type": "string", "minLength": 1 },
        "demoted_continuation": { "type": "string", "minLength": 1 },
